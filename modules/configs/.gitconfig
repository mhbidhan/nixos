[include]
  path = .catppuccin.gitconfig

[core]
  pager = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  features = catppuccin-mocha
  syntax-theme = Catppuccin Mocha
  side-by-side = true
  line-numbers = true
  navigate = true

[merge]
  conflictstyle = diff3

[diff]
  colorMoved = default
